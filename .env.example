# Application configuration
ENVIRONMENT=development
PROJECT_NAME="L&D Enterprise AI SaaS"
API_V1_STR="/api/v1"

# Security configurations
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY="dev_secret_key_change_me_in_production_1234567890"
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 days

# PostgreSQL Database configurations
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_pass
POSTGRES_DB=ld_platform
POSTGRES_PORT=5432

# Redis configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# AI Provider configurations
# Supported: gemini, mock (future: openai, claude)
LLM_PROVIDER=gemini
GEMINI_API_KEY="YOUR_GOOGLE_GEMINI_API_KEY"

# Model names
DEFAULT_MODEL=gemini-2.5-flash
PREMIUM_MODEL=gemini-2.5-pro
EMBEDDING_MODEL=text-embedding-004
